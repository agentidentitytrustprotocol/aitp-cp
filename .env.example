# Server
PORT=4000
CP_BASE_URL=http://localhost:4000

# CP identity — REQUIRED in production. Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CP_AID_SEED_HEX=

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aitp_control_plane
DB_POOL_MAX=20

# API key list (comma-separated). Empty = auth disabled.
# REQUIRED in production (NODE_ENV=production) — admin endpoints like
# /api/webhooks, /api/audit, and DELETE /api/registry/agents/:aid will
# 503 if this is unset in prod, to prevent accidental public exposure.
API_KEYS=

# Enrollment token signing secret (REQUIRED). Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENROLLMENT_SECRET=

# CORS origin — REQUIRED in production. Set to the UI plane origin.
# Falls back to "*" with a warning if unset on NODE_ENV=production.
CORS_ORIGIN=http://localhost:3000

# ── Multi-tenancy note ───────────────────────────────────────────────
# `GET /api/registry/agents` without `?namespace=` returns rows across
# ALL namespaces by design (RFC-AITP-0007 discovery semantics). If you
# rely on per-tenant isolation, your caller MUST set
# `?namespace=<tenant>` on discovery and `X-Aitp-Namespace: <tenant>`
# on enrollment. The CP enforces no implicit tenancy boundary.

# Revocation list TTL (seconds)
REVOCATION_LIST_TTL_SECS=3600

# Webhook retry attempts (per delivery)
WEBHOOK_RETRY_ATTEMPTS=3

# SSE backlog size (in-memory)
MAX_AUDIT_EVENTS_MEMORY=500

# Logging
LOG_LEVEL=info
